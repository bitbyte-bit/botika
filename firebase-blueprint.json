{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information and role",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "seller", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "businessName": { "type": "string" },
        "businessDescription": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Boutique product details and inventory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "stock": { "type": "number" },
        "isAuthentic": { "type": "boolean" },
        "authenticationDetails": { "type": "string" },
        "ratingAvg": { "type": "number" },
        "reviewCount": { "type": "number" },
        "sellerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "visitCount": { "type": "number" },
        "likeCount": { "type": "number" }
      },
      "required": ["name", "price", "stock", "sellerId"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order and tracking information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "paymentId": { "type": "string" },
        "trackingNumber": { "type": "string" },
        "sellerIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "items", "total", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "Product rating and feedback",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/products/{productId}": { "schema": "Product", "description": "Product catalog" },
    "/orders/{orderId}": { "schema": "Order", "description": "Customer orders" },
    "/reviews/{reviewId}": { "schema": "Review", "description": "Product reviews" }
  }
}
